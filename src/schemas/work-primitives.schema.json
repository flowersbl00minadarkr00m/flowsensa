{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/work-primitives.schema.json",
  "title": "Governed Work Primitive Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "registryVersion", "entries"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "registryVersion": { "type": "string", "minLength": 1 },
    "effectiveAt": { "type": "string", "format": "date-time" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "term",
        "primitiveType",
        "meaningStatus",
        "definition",
        "scope",
        "owner",
        "sourceRef",
        "version",
        "effectiveFrom"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "term": { "type": "string", "minLength": 1 },
        "aliases": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "primitiveType": {
          "enum": [
            "actor",
            "intent",
            "object",
            "action",
            "state",
            "decision",
            "authority",
            "evidence",
            "control",
            "exception",
            "handoff",
            "outcome",
            "other"
          ]
        },
        "meaningStatus": {
          "enum": ["official", "operational", "historical", "contested", "inferred"]
        },
        "definition": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "sourceRef": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "effectiveFrom": { "type": "string", "format": "date-time" },
        "effectiveTo": { "type": ["string", "null"], "format": "date-time" },
        "examples": { "type": "array", "items": { "type": "string" } },
        "counterexamples": { "type": "array", "items": { "type": "string" } },
        "relatedTerms": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "validationRules": { "type": "array", "items": { "type": "string" } },
        "consumers": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "notes": { "type": "string" }
      }
    }
  }
}
